{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "packages": {
      "type": "object",
      "properties": {
        "analyze": {
          "default": [],
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "kind": {
                    "type": "string",
                    "enum": [
                      "http-client",
                      "broker-client",
                      "db-client"
                    ]
                  },
                  "label": {
                    "type": "string"
                  },
                  "baseUrl": {
                    "type": "string"
                  },
                  "provider": {
                    "type": "string",
                    "enum": [
                      "rabbitmq",
                      "kafka",
                      "pubsub",
                      "sqs",
                      "sns",
                      "azure-service-bus",
                      "nats",
                      "redis-streams",
                      "pulsar"
                    ]
                  }
                },
                "required": [
                  "name",
                  "kind"
                ]
              }
            ]
          }
        },
        "ignore": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "decorators": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "message-consumer",
              "http-route",
              "scheduled-job",
              "graphql-client",
              "http-client"
            ]
          },
          "args": {
            "default": [
              "routingKey",
              "queue",
              "name",
              "topic"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "pathArgIndex": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "httpMethod": {
            "default": "POST",
            "type": "string",
            "enum": [
              "GET",
              "POST",
              "PUT",
              "PATCH",
              "DELETE",
              "HEAD",
              "OPTIONS"
            ]
          }
        },
        "required": [
          "name",
          "kind"
        ]
      }
    },
    "databases": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "technology": {
            "type": "string"
          },
          "shared": {
            "default": false,
            "type": "boolean"
          },
          "tables": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "technology"
        ]
      }
    },
    "hints": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "patterns": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Keywords, class names, or function names that identify this pattern in source code"
          },
          "description": {
            "type": "string",
            "description": "Natural language instruction for the LLM. E.g. \"Internal wrapper for GCP Pub/Sub. Treat .publish() first arg as the topic name.\""
          }
        },
        "required": [
          "patterns",
          "description"
        ]
      }
    },
    "message_channels": {
      "default": {
        "aliases": [],
        "mirrors": [],
        "class_routes": []
      },
      "type": "object",
      "properties": {
        "aliases": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "channelKind": {
                "type": "string",
                "enum": [
                  "topic",
                  "subscription",
                  "queue",
                  "exchange"
                ]
              },
              "technology": {
                "type": "string"
              },
              "schemaPath": {
                "type": "string"
              },
              "schemaFormat": {
                "type": "string",
                "enum": [
                  "avro",
                  "json-schema",
                  "protobuf"
                ]
              },
              "topic": {
                "type": "string"
              },
              "tags": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "from",
              "name",
              "channelKind"
            ]
          }
        },
        "mirrors": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "logical": {
                "type": "string"
              },
              "kind": {
                "default": "topic",
                "type": "string",
                "enum": [
                  "topic",
                  "subscription",
                  "queue",
                  "exchange"
                ]
              },
              "physical": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "broker": {
                      "type": "string"
                    },
                    "channel": {
                      "type": "string"
                    },
                    "kind": {
                      "type": "string",
                      "enum": [
                        "topic",
                        "subscription",
                        "queue",
                        "exchange"
                      ]
                    }
                  },
                  "required": [
                    "broker",
                    "channel",
                    "kind"
                  ]
                }
              }
            },
            "required": [
              "logical",
              "physical"
            ]
          }
        },
        "class_routes": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "class": {
                "type": "string"
              },
              "routing_key": {
                "type": "string"
              }
            },
            "required": [
              "class",
              "routing_key"
            ]
          }
        }
      }
    },
    "messageBrokers": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "provider": {
            "type": "string",
            "enum": [
              "rabbitmq",
              "kafka",
              "pubsub",
              "sqs",
              "sns",
              "azure-service-bus",
              "nats",
              "pulsar",
              "redis-streams",
              "mqtt",
              "mosquitto",
              "zeromq",
              "symfony-messenger"
            ]
          },
          "cluster": {
            "type": "string"
          },
          "host": {
            "type": "string"
          },
          "port": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "vhost": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "env": {
            "type": "string"
          },
          "fingerprint": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "provider"
        ]
      }
    },
    "crossplane": {
      "type": "object",
      "properties": {
        "crds": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string"
              },
              "channelKind": {
                "type": "string",
                "enum": [
                  "topic",
                  "subscription"
                ]
              },
              "nameField": {
                "type": "string"
              },
              "topicField": {
                "type": "string"
              },
              "technology": {
                "default": "pubsub",
                "type": "string"
              }
            },
            "required": [
              "kind",
              "channelKind",
              "nameField"
            ]
          }
        }
      }
    },
    "envAccessors": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "callee": {
            "type": "string"
          },
          "keyArg": {
            "default": 0,
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "defaultArg": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "callee"
        ]
      }
    },
    "sink_classifier": {
      "type": "object",
      "properties": {
        "mode": {
          "default": "enabled",
          "type": "string",
          "enum": [
            "disabled",
            "enabled",
            "force-refresh"
          ]
        },
        "bootstrap_mode": {
          "default": "nonblocking",
          "type": "string",
          "enum": [
            "blocking",
            "nonblocking"
          ]
        },
        "confidence_threshold": {
          "default": 0.7,
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_packages_per_batch": {
          "default": 200,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "timeout_ms": {
          "default": 60000,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "cache": {
          "default": {
            "backend": "file",
            "ttl_days": 90
          },
          "type": "object",
          "properties": {
            "backend": {
              "default": "file",
              "type": "string",
              "enum": [
                "file"
              ]
            },
            "ttl_days": {
              "default": 90,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "additionalProperties": false
        },
        "budget": {
          "default": {
            "max_llm_tokens_per_run": 200000,
            "max_usd_per_run": 0.5,
            "concurrency": 2
          },
          "type": "object",
          "properties": {
            "max_llm_tokens_per_run": {
              "default": 200000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "max_usd_per_run": {
              "default": 0.5,
              "type": "number",
              "exclusiveMinimum": 0
            },
            "concurrency": {
              "default": 2,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "additionalProperties": false
        },
        "privacy": {
          "default": {
            "deny_patterns": [],
            "allow_patterns": [],
            "on_denied": "classify_as_sink"
          },
          "type": "object",
          "properties": {
            "deny_patterns": {
              "default": [],
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allow_patterns": {
              "default": [],
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "on_denied": {
              "default": "classify_as_sink",
              "type": "string",
              "enum": [
                "classify_as_sink",
                "classify_as_ignore",
                "hardcoded_only"
              ]
            }
          },
          "additionalProperties": false
        },
        "drift": {
          "default": {
            "alert_on_disagreement": false,
            "alert_threshold": 5
          },
          "type": "object",
          "properties": {
            "alert_on_disagreement": {
              "default": false,
              "type": "boolean"
            },
            "alert_threshold": {
              "default": 5,
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "services": {
      "type": "object",
      "properties": {
        "topology": {
          "default": "auto",
          "type": "string",
          "enum": [
            "monolith",
            "monorepo",
            "auto"
          ]
        },
        "nameOverrides": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "overrides": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "role": {
                "type": "string",
                "enum": [
                  "deployment-facet",
                  "independent-service"
                ]
              }
            },
            "required": [
              "role"
            ]
          }
        }
      }
    },
    "ingestion": {
      "type": "object",
      "properties": {
        "maxFieldsPerPayload": {
          "default": 50,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      }
    }
  },
  "additionalProperties": false
}
