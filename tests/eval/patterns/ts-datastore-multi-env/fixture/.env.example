# Anonymised multi-environment datastore fixture (acme/orders).
#
# Three distinct DSN keys for the SAME logical database ("orders"), one per
# deployment environment. Distinct keys are required because buildRepoEnvMap
# collapses the env-map first-writer-wins PER KEY — a single repeated key
# (e.g. DATABASE_URL in .env + .env.production) would keep only one winner.
#
# The carrier file is `.env.example` (scanned by ENV_FILE_PRIORITY, NOT
# gitignored, and crucially its NAME contains no env token) so the environment
# class is derived from each dbName suffix, not from the filename.
PROD_DATABASE_URL=mysql://orders-prod.acme.internal:3306/orders_production
STAGING_DATABASE_URL=mysql://orders-stg.acme.internal:3306/orders_staging
DEV_DATABASE_URL=mysql://orders-dev.acme.internal:3306/orders_development
